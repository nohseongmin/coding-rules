# EditorConfig — https://editorconfig.org
# Enforces basic formatting consistency (Part 2 / P0-2) across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,java,go,rs}]
indent_size = 4

[*.md]
# Markdown: trailing spaces can be meaningful (hard line break)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
